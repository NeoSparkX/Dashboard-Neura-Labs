rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // campaign_applications:
    // Public can CREATE only (form submission from main site)
    // Authenticated users (dashboard) can READ and UPDATE
    match /campaign_applications/{docId} {
      allow create: if
        request.resource.data.agreed_to_terms == true &&
        request.resource.data.status == "pending" &&
        request.resource.data.keys().hasAll([
          'full_name', 'email', 'phone', 'business_name',
          'service_types', 'project_brief', 'agreed_to_terms',
          'campaign_id', 'submitted_at'
        ]);
      allow read, update: if request.auth != null;
      allow delete: if false;   // never delete — archive via status field
    }

    // All other collections: authenticated only (existing behavior — no change)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
